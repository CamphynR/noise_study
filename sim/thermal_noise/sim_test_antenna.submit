Requirements = (!regexp("^node31", Machine) && !regexp("^node33", Machine) && !regexp("^node36", Machine) && !regexp("^node38", Machine) && !regexp("^node37-6", Machine))
getenv=True
STATION=11
INDEX=0
batch_name=thermal_noise_sim_s$(STATION)_antenna_n1.$(INDEX)0

executable = /user/rcamphyn/envs/mattak_env/bin/python3
arguments = /user/rcamphyn/noise_study/sim/thermal_noise/generate_thermal_noise_traces.py --station $(STATION) --config sim/thermal_noise/configs/config_test_antenna_models/config_test_antenna_model_v4_n1.$(INDEX)0.json --batch_i $(Process) --name_appendix antenna_v4_final_IGLU_n1.$(INDEX)0
log = /user/rcamphyn/noise_study/submit/sim_logs/thermal_noise_$(STATION)_n1.$(INDEX)0.log
output = /user/rcamphyn/noise_study/submit/sim_logs/thermal_noise_$(STATION)_n1.$(INDEX)0.out
error = /user/rcamphyn/noise_study/submit/sim_logs/thermal_noise_$(STATION)_n1.$(INDEX)0.err
request_cpus = 1
request_memory = 4000MB
request_disk = 5GB
should_transfer_files = NO
queue 64
