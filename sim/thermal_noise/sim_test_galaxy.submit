
getenv=True
STATION=11
batch_name=thermal_noise_sim_s$(STATION)_galaxy_gsm2016

executable = /user/rcamphyn/envs/mattak_env/bin/python3
arguments = /user/rcamphyn/noise_study/sim/thermal_noise/generate_thermal_noise_traces.py --station $(STATION) --config sim/thermal_noise/configs/config_test_galaxy/sim_gsm2016.json --batch_i $(Process) --name_appendix galaxy_gsm2016
log = /user/rcamphyn/noise_study/submit/sim_logs/thermal_noise_$(STATION)_gal.log
output = /user/rcamphyn/noise_study/submit/sim_logs/thermal_noise_$(STATION)_gal.out
error = /user/rcamphyn/noise_study/submit/sim_logs/thermal_noise_$(STATION)_gal.err
request_cpus = 1
request_memory = 4000MB
request_disk = 5GB
should_transfer_files = NO
queue 64
